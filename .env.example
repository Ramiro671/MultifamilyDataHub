# =============================================================================
# MultifamilyDataHub — Environment Variables
# =============================================================================
# Copy this file to .env (gitignored) and fill in real values.
# .env is loaded automatically by docker-compose for local development.
#
# AZURE CONTAINER APPS — secret mapping
# Each variable below maps to a Container Apps secret injected as an env var:
#
#   .env variable          Container Apps secret name   Env var in container
#   ---------------------  ---------------------------  --------------------
#   ANTHROPIC_API_KEY      anthropic-api-key            Anthropic__ApiKey
#   SQL_CONNECTION_STRING  sql-connection-string        SQL_CONNECTION_STRING
#   MONGO_CONNECTION_STRING mongo-connection-string     MONGO_CONNECTION_STRING
#   JWT_SECRET             jwt-secret                   JWT_SECRET
#
# In production (Azure), these values come from infra/main.parameters.json
# (gitignored). Never put real secrets in this file.
# =============================================================================

# Anthropic Claude API key — required by MDH.InsightsService only.
# Local: ANTHROPIC_API_KEY is read directly.
# Azure: Container Apps injects it as Anthropic__ApiKey (double-underscore = colon in config).
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# SQL Server connection string — MDH.OrchestrationService + MDH.AnalyticsApi.
# Local: SQL Server 2022 via docker-compose (port 1433).
# Azure: Azure SQL serverless (auto-pause; cold-start ~60s — retry logic handles this).
SQL_CONNECTION_STRING=Server=localhost,1433;Database=MDH;User Id=sa;Password=Your_Strong_P@ss;TrustServerCertificate=True;

# MongoDB connection string — MDH.IngestionService + MDH.OrchestrationService.
# Local: MongoDB 7 via docker-compose (port 27017).
# Azure: Cosmos DB for MongoDB API (free tier, 1000 RU/s).
MONGO_CONNECTION_STRING=mongodb://mdh:mdh@localhost:27017

# MongoDB database name — used by both Ingestion and Orchestration.
MONGO_DB=mdh_raw

# JWT HS256 signing secret — shared by MDH.AnalyticsApi and MDH.InsightsService.
# Must be at least 64 characters. Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-64-char-random-string-here-minimum-64-bytes-pls
