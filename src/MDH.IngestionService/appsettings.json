{
  "Ingestion": {
    "IntervalSeconds": 10
  },
  "Mongo": {
    "Database": "mdh_raw"
  },
  "ConnectionStrings": {
    "MongoDB": "mongodb://mdh:mdh@localhost:27017"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
